lambda_functions_v*.zip
Install_new.docx

# Vendored dependencies installed into lambda_functions/ by CI via
# `pip install -r requirements.txt -t .`. The previous version of this
# file enumerated every file in every vendored package (~1800 lines);
# patterns below cover the same ground in a few lines and adding a new
# dep is a one-line change.
#
# If you add a new top-level dep that pip lays down a directory for,
# add its package name (and matching *.dist-info/) here.
lambda_functions/ask_sdk/
lambda_functions/ask_sdk_core/
lambda_functions/ask_sdk_model/
lambda_functions/ask_sdk_runtime/
lambda_functions/boto3/
lambda_functions/botocore/
lambda_functions/certifi/
lambda_functions/charset_normalizer/
lambda_functions/dateutil/
lambda_functions/idna/
lambda_functions/jmespath/
lambda_functions/requests/
lambda_functions/s3transfer/
lambda_functions/urllib3/
lambda_functions/bin/
lambda_functions/six.py
lambda_functions/*.dist-info/
lambda_functions/__pycache__/

# CLAUDE.md and other AI assistant artifacts are excluded locally via
# .git/info/exclude (intentionally not in this committed file — keeps
# the public repo free of any AI-tooling footprint).
